<!DOCTYPE html>
<html>
<head>
    <title>Background and Borders Example</title>

    <style>
        /* Background for whole page */
        body {
            background-color: lightblue;   /* Background color */
            background-image: url("background.jpg"); /* Background image */
            background-size: cover;
            background-repeat: no-repeat;
        }

        /* Border for heading */
        h1 {
            border: 3px solid red;
            padding: 10px;
        }

        /* Border for paragraph */
        p {
            border: 2px dashed green;
            padding: 10px;
        }

        /* Border for div */
        div {
            border: 4px dotted blue;
            padding: 10px;
            margin-top: 10px;
        }
    </style>
</head>

<body>

    <h1>Heading with Solid Border</h1>

    <p>Paragraph with Dashed Border</p>

    <div>Div with Dotted Border</div>

</body>
</html>
