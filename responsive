<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Navigation and Overflow</title>

<style>

/* ========== HORIZONTAL MENU ========== */
.topnav {
  background: black;
  overflow: hidden;
}

.topnav a {
  float: left;
  color: white;
  padding: 14px;
  text-decoration: none;
}

.topnav a:hover {
  background: gray;
}

/* ========== VERTICAL MENU ========== */
.vertical {
  width: 200px;
  background: lightgray;
}

.vertical a {
  display: block;
  padding: 10px;
  text-decoration: none;
  color: black;
}

.vertical a:hover {
  background: gray;
  color: white;
}

/* ========== DROPDOWN MENU ========== */
.dropdown {
  position: relative;
  display: inline-block;
}

.dropdown-content {
  display: none;
  position: absolute;
  background: white;
  min-width: 120px;
  border: 1px solid black;
}

.dropdown-content a {
  display: block;
  padding: 8px;
  text-decoration: none;
  color: black;
}

.dropdown:hover .dropdown-content {
  display: block;
}

/* ========== RESPONSIVE MENU (CSS ONLY) ========== */
.responsive {
  background: darkblue;
}

.responsive a {
  display: block;
  color: white;
  padding: 10px;
  text-decoration: none;
}

@media (min-width: 600px) {
  .responsive a {
    display: inline-block;
  }
}

/* ========== OVERFLOW EXAMPLES ========== */
.box {
  width: 200px;
  height: 80px;
  border: 1px solid black;
  overflow: auto;
  margin-top: 10px;
}

.text-box {
  width: 150px;
  height: 50px;
  border: 1px solid red;
  overflow: hidden;
}

.img-container {
  width: 150px;
  height: 100px;
  overflow: hidden;
  border: 1px solid blue;
}

.img-container img {
  width: 200px;
}

/* Scrollable dropdown */
.scroll-dropdown {
  width: 150px;
  height: 60px;
  overflow-y: scroll;
  border: 1px solid black;
}

/* ========== DISPLAY TYPES ========== */
.inline {
  display: inline;
  background: yellow;
}

.block {
  display: block;
  background: lightgreen;
}

.inline-block {
  display: inline-block;
  width: 100px;
  height: 40px;
  background: orange;
}

</style>
</head>

<body>

<h2>Horizontal Menu</h2>
<div class="topnav">
  <a href="#">Home</a>
  <a href="#">About</a>
  <a href="#">Contact</a>
</div>

<h2>Vertical Menu</h2>
<div class="vertical">
  <a href="#">Link 1</a>
  <a href="#">Link 2</a>
  <a href="#">Link 3</a>
</div>

<h2>Dropdown Menu</h2>
<div class="dropdown">
  <button>Menu</button>
  <div class="dropdown-content">
    <a href="#">Sub 1</a>
    <a href="#">Sub 2</a>
  </div>
</div>

<h2>Responsive Menu</h2>
<div class="responsive">
  <a href="#">Home</a>
  <a href="#">Services</a>
  <a href="#">Contact</a>
</div>

<h2>Overflow Examples</h2>

<div class="box">
  This is a container with fixed height. Content will scroll if it overflows.
  More text... More text... More text...
</div>

<div class="text-box">
  This text is hidden because overflow is hidden.
</div>

<div class="img-container">
  <img src="https://via.placeholder.com/200" alt="image">
</div>

<div class="scroll-dropdown">
  Item 1<br>Item 2<br>Item 3<br>Item 4<br>Item 5
</div>

<h2>Display Types</h2>
<span class="inline">Inline</span>
<div class="block">Block</div>
<div class="inline-block">Inline-Block</div>

</body>
</html>
