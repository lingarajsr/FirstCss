<!DOCTYPE html>
<html>
<head>
<style>
/* Universal Selector */
* {
  font-family: Arial;
}

/* Element Selector */
h1 {
  color: blue;
}

/* Class Selector */
.box {
  color: green;
}

/* ID Selector */
#special {
  color: red;
}

/* Group Selector */
h2, p {
  background-color: lightgray;
}

/* Descendant Selector */
div p {
  font-style: italic;
}

/* Hover (Pseudo-class) */
a:hover {
  color: orange;
}
</style>
</head>
<body>

<h1>Element Selector</h1>

<h2>Group Selector</h2>

<p>Paragraph styled by group selector</p>

<div>
  <p>Descendant Selector</p>
</div>

<p class="box">Class Selector</p>

<p id="special">ID Selector</p>

<a href="#">Hover over me</a>

</body>
</html>
